0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen bg-[#F5F0E6] py-16 px-4 md:px-8 font-sans","children":["$","div",null,{"className":"max-w-4xl mx-auto bg-white rounded-[2.5rem] p-8 md:p-16 shadow-xl border border-[#D4A373]/10","children":[["$","div",null,{"className":"text-center mb-12 border-b border-gray-100 pb-8","children":[["$","span",null,{"className":"text-[#D4A373] font-bold uppercase tracking-[0.2em] text-xs mb-3 block","children":"Müşteri Hizmetleri"}],["$","h1",null,{"className":"text-3xl md:text-4xl font-black text-[#5e0d0f] leading-tight","children":"İPTAL VEYA İADE KOŞULLARI"}],["$","div",null,{"className":"w-20 h-1 bg-[#D4A373] mx-auto rounded-full mt-4"}]]}],["$","div",null,{"className":"space-y-8 text-gray-700 text-sm md:text-base leading-relaxed font-medium","children":[["$","section",null,{"className":"bg-[#FBF9F4] p-6 rounded-2xl border border-[#D4A373]/10","children":[["$","h2",null,{"className":"text-lg font-extrabold text-[#5e0d0f] mb-3 flex items-center gap-2","children":[["$","span",null,{"className":"bg-[#5e0d0f] text-white w-6 h-6 rounded-md flex items-center justify-center text-xs","children":"1"}],"İPTAL KOŞULLARI"]}],["$","p",null,{"className":"text-gray-600 pl-1","children":["Siparişinizin iptal işlemlerini, siparişiniz kargoya teslim edilmeden önce gerçekleştirmeniz gerekmektedir. Sipariş durumunuz \"Kargoya Verildi\" aşamasına geçmeden önce ",["$","span",null,{"className":"text-[#5e0d0f] font-bold","children":"kocacinarciftlik@gmail.com"}]," adresine e-posta göndererek veya ",["$","span",null,{"className":"text-[#5e0d0f] font-bold","children":"+90 551 340 48 48"}]," numaralı WhatsApp destek hattımızdan bize ulaşarak iptal talebinizi iletebilirsiniz. İptal edilen siparişlerin ücret iadesi, ödemeyi yaptığınız İyzico altyapısı üzerinden aynı gün içinde bankanıza iletilir. Bankaların iadeyi kartınıza yansıtma süresi ortalama 1-3 iş günüdür."]}]]}],["$","section",null,{"className":"p-2 border-l-4 border-amber-500 pl-4 my-6","children":[["$","h2",null,{"className":"text-lg font-extrabold text-[#5e0d0f] mb-3 flex items-center gap-2","children":[["$","span",null,{"className":"bg-amber-500 text-white w-6 h-6 rounded-md flex items-center justify-center text-xs","children":"2"}],"CAYMA HAKKI VE İSTİSNALARI (TAZE & BOZULABİLİR GIDA)"]}],["$","p",null,{"className":"text-gray-600 mb-3","children":"Koca Çınar Şarküteri üzerinden satışı yapılan ürünlerin büyük bir kısmı taze gıda, şarküteri ürünleri (peynir, sucuk, zeytin, et ürünleri vb.) ve ısı değişimlerine karşı hassas organik ürünlerden oluşmaktadır."}],["$","p",null,{"className":"text-gray-600 font-semibold bg-amber-50 p-4 rounded-xl text-xs md:text-sm border border-amber-200 leading-relaxed","children":"⚠️ 27.11.2014 tarihli Mesafeli Sözleşmeler Yönetmeliği'nin \"Cayma Hakkı İstisnaları\" başlıklı 15. Maddesinin (c) bendi uyarınca; \"Çabuk bozulabilen veya son kullanma tarihi geçebilecek malların teslimine ilişkin sözleşmelerde\" tüketicinin cayma hakkı bulunmamaktadır. Bu sebeple, soğuk zincir ile veya standart kargo ile gönderilen tüm taze şarküteri ürünleri, kahvaltılıklar ve ısıya duyarlı gıdalarda sağlık ve hijyen kuralları gereği sebepsiz yere iade veya değişim yapılamamaktadır."}],["$","p",null,{"className":"text-gray-600 mt-3","children":"Ambalajı açılmamış, vakumu bozulmamış ve soğuk zincir gerektirmeyen (örneğin kapalı kavanoz reçel, konserve, baharat gibi) dayanıklı kuru gıda ürünlerinde ise ürünü teslim aldığınız tarihten itibaren 14 (on dört) gün içinde cayma hakkınızı kullanarak iade talebinde bulunabilirsiniz. İade edilecek ürünün ticari vasfını yitirmemiş olması şarttır."}]]}],"$L2"]}]]}]}],null,"$L3"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"bL1GLC90hylUjJOi0GUXn"}
2:["$","section",null,{"className":"p-2","children":[["$","h2",null,{"className":"text-lg font-extrabold text-[#5e0d0f] mb-4 flex items-center gap-2","children":[["$","span",null,{"className":"bg-[#5e0d0f] text-white w-6 h-6 rounded-md flex items-center justify-center text-xs","children":"3"}],"HASARLI, KUSURLU VEYA YANLIŞ ÜRÜN İADELERİ"]}],["$","p",null,{"className":"mb-4 text-gray-600","children":"Müşteri memnuniyeti Koca Çınar Şarküteri için en büyük önceliktir. Siparişinizin kargo aşamasında hasar görmesi (kavanoz kırılması, vakum patlaması vb.) veya size yanlış/kusurlu ürün gönderilmesi durumunda aşağıdaki adımları izlemeniz gerekmektedir:"}],["$","div",null,{"className":"space-y-3","children":[["$","div",null,{"className":"flex gap-3 bg-[#FBF9F4] p-4 rounded-xl border border-gray-100","children":[["$","span",null,{"className":"text-red-600 font-bold","children":"📦"}],["$","span",null,{"className":"text-sm text-gray-600","children":["Kargoyu teslim alırken pakette gözle görülür bir ezilme, akma veya yırtılma varsa kargo görevlisine ",["$","strong",null,{"children":"Hasar Tespit Tutanağı"}]," tutturarak paketi teslim almayınız."]}]]}],["$","div",null,{"className":"flex gap-3 bg-[#FBF9F4] p-4 rounded-xl border border-gray-100","children":[["$","span",null,{"className":"text-red-600 font-bold","children":"📸"}],["$","span",null,{"className":"text-sm text-gray-600","children":["Ürünü açtıktan sonra bir sorun (bozulma, vakum kaçağı, yanlış ürün) tespit ederseniz, ürünü teslim aldığınız gün içinde (24 saat içerisinde) ürünün fotoğraflarını çekerek ",["$","strong",null,{"children":"+90 551 340 48 48"}]," numaralı WhatsApp hattımıza veya e-posta adresimize iletiniz."]}]]}],["$","div",null,{"className":"flex gap-3 bg-[#FBF9F4] p-4 rounded-xl border border-gray-100","children":[["$","span",null,{"className":"text-green-600 font-bold","children":"🛡️"}],["$","span",null,{"className":"text-sm text-gray-600","children":"Şikayetiniz ekiplerimizce incelendikten sonra haklı bulunması durumunda, mağduriyetiniz yeni ürün gönderimi veya ücret iadesi yapılmak suretiyle derhal giderilecektir."}]]}]]}]]}]
